    <SolidColorBrush x:Key="PrimaryBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="ExpenseBrush" Color="#FF5722"/>
    <SolidColorBrush x:Key="IncomeBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="GoalsBrush" Color="#2196F3"/>
    <SolidColorBrush x:Key="ChartsBrush" Color="#9C27B0"/>
    <SolidColorBrush x:Key="PetBrush" Color="#FFC107"/> 
    <SolidColorBrush x:Key="ProfileBrush" Color="#757575"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#757575"/>
    <SolidColorBrush x:Key="EnergyBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="FoodBrush" Color="#FF9800"/>

    <!-- ========== СТИЛИ ========== -->

    <!-- Стиль для кнопок -->
    <Style x:Key="MainMenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Height" Value="80"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                        CornerRadius="15"
                        BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Стиль для кнопки профиля -->
    <Style x:Key="ProfileButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ProfileBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для карточек -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Стиль для заголовков -->
    <Style x:Key="HeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Стиль для подзаголовков -->
    <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Стиль для текста с валютой -->
    <Style x:Key="CurrencyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- Стиль для текста с кормом -->
    <Style x:Key="FoodTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource FoodBrush}"/>
    </Style>

    <!-- Стиль для прогресс-бара энергии -->
    <Style x:Key="EnergyProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Foreground" Value="{StaticResource EnergyBrush}"/>
        <Setter Property="Background" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</ResourceDictionary>