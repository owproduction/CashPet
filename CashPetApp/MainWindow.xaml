<Window x:Class="FinancialTamagotchi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовый Тамагоччи" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0FF00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Фоновое изображение -->
        <Image x:Name="BackgroundImage" Source="back.png" Stretch="Fill" Opacity="1"/>
        
        <!-- Основной контейнер с закруглёнными углами -->
        <Border CornerRadius="30" Background="Transparent" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========== ЛЕВАЯ БОКОВАЯ ПАНЕЛЬ ========== -->
                <Border x:Name="SideMenuBorder" 
                        Grid.Column="0" 
                        Background="#B4F73D"
                        CornerRadius="30,0,0,30"
                        Width="80">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#601AC2" CornerRadius="30,0,0,0">
                            <Button x:Name="MenuToggleButton"
                                    Content="☰"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontSize="20"
                                    Width="40"
                                    Height="40"
                                    Cursor="Hand"
                                    HorizontalAlignment="Left"
                                    Margin="20,0,0,0"
                                    Click="MenuToggleButton_Click"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <Button x:Name="ExpenseButton" Style="{StaticResource MenuButtonStyle}" Click="ExpenseButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💸" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="ExpenseText" Text="Добавить трату" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IncomeButton" Style="{StaticResource MenuButtonStyle}" Click="IncomeButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💰" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="IncomeText" Text="Добавить доход" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="GoalsButton" Style="{StaticResource MenuButtonStyle}" Click="GoalsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="GoalsText" Text="Мои цели" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ChartsButton" Style="{StaticResource MenuButtonStyle}" Click="ChartsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="ChartsText" Text="Графики" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="SettingsButton" Style="{StaticResource MenuButtonStyle}" Click="SettingsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="SettingsText" Text="Настройки" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,20">
                            <Button x:Name="ProfileButton" Style="{StaticResource MenuButtonStyle}" Click="ProfileButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="22" Width="40"/>
                                    <TextBlock x:Name="ProfileText" Text="Профиль" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- ========== ПРАВАЯ ЧАСТЬ ========== -->
                <Border Grid.Column="1" CornerRadius="0,30,30,0" Background="Transparent">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                        <StackPanel Margin="30">

                            <!-- Верхняя панель -->
                            <Border Height="60" Margin="0,0,0,24" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="WelcomeText" 
                                               Grid.Column="0"
                                               Text="Добро пожаловать!" 
                                               FontSize="24" 
                                               FontWeight="Bold"
                                               Foreground="#601AC2"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#DBBEFF" CornerRadius="20" Padding="12,6,12,6" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🥕" FontSize="16"/>
                                                <TextBlock x:Name="FoodCurrencyText" Text="100" FontSize="14" FontWeight="Bold" Foreground="#601AC2" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#DBBEFF" CornerRadius="20" Padding="12,6,12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🍯" FontSize="16"/>
                                                <TextBlock x:Name="BalanceText" Text="15 000 ₽" FontSize="14" FontWeight="Bold" Foreground="#601AC2" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Карточка питомца -->
                            <Border Background="White" CornerRadius="20" Padding="24" Margin="0,0,0,24" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="PetBorder" Grid.Column="0" Width="100" Height="100" Background="#DBBEFF" CornerRadius="50" Margin="0,0,24,0">
                                        <TextBlock x:Name="PetEmoji" Text="🐹" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="PetNameText" Text="Копилко-хомяк" FontSize="20" FontWeight="Bold" Foreground="#601AC2" Margin="0,0,0,8"/>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,8">
                                                <TextBlock Text="🍯" FontSize="14" Width="24"/>
                                                <TextBlock Text="Баланс:" FontSize="14" Foreground="#625A5A"/>
                                                <TextBlock x:Name="PetBalanceText" Text="15 000 ₽" FontSize="14" FontWeight="Bold" Foreground="#601AC2" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="🥕" FontSize="14" Width="24"/>
                                                <TextBlock Text="Корм:" FontSize="14" Foreground="#625A5A"/>
                                                <TextBlock x:Name="FoodText" Text="100" FontSize="14" FontWeight="Bold" Foreground="#601AC2" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,8">
                                                <TextBlock Text="😊" FontSize="14" Width="24"/>
                                                <TextBlock Text="Настроение:" FontSize="14" Foreground="#625A5A"/>
                                                <TextBlock x:Name="MoodText" Text="Отличное!" FontSize="14" FontWeight="SemiBold" Foreground="#AA6AE2" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="⚡" FontSize="14" Width="24"/>
                                                <TextBlock Text="Энергия:" FontSize="14" Foreground="#625A5A"/>
                                                <TextBlock x:Name="EnergyPercent" Text="80%" FontSize="14" FontWeight="Bold" Foreground="#601AC2" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <ProgressBar x:Name="EnergyBar" Value="80" Maximum="100" Height="8" Foreground="#D0FF00" Background="#D9D9D9" Margin="0,8,0,12"/>

                                        <Button x:Name="FeedPetButton" 
                                                Content="🥕 Покормить (10 корма)"
                                                Background="#601AC2"
                                                Foreground="White"
                                                FontSize="13"
                                                Height="36"
                                                Cursor="Hand"
                                                HorizontalAlignment="Left"
                                                Width="180"
                                                Click="FeedPetButton_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Уведомление -->
                            <Border x:Name="NotificationBorder" Background="#DBBEFF" CornerRadius="12" Padding="16,12,16,12" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔔" FontSize="20" Margin="0,0,12,0"/>
                                    <TextBlock x:Name="NotificationText" Grid.Column="1" Text="новое уведомление!" FontSize="14" FontWeight="Medium" Foreground="#601AC2" VerticalAlignment="Center"/>
                                    <Button x:Name="CloseNotificationButton" Grid.Column="2" Content="✕" Background="Transparent" BorderThickness="0" Foreground="#601AC2" Cursor="Hand" FontSize="14" Width="24" Height="24" Click="CloseNotificationButton_Click"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Выберите действие в меню слева" FontSize="14" Foreground="#625A5A" HorizontalAlignment="Center" Margin="0,40,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>