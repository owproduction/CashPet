<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 Мои цели"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/purple_1"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/goalsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нет активных целей. Создайте новую!"
        android:textSize="14sp"
        android:textColor="@color/gray_1"
        android:textAlignment="center"
        android:visibility="gone"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnCreateGoal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="+ Создать новую цель"
        android:backgroundTint="@color/purple_1"
        android:textColor="@color/white"
        android:layout_marginTop="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>