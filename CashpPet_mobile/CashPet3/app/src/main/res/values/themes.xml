<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тема -->
    <style name="Theme.CashPet3" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Статус бар и навигейшн бар -->
        <item name="android:statusBarColor">@color/purple_1</item>
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Цвета -->
        <item name="colorPrimary">@color/purple_1</item>
        <item name="colorPrimaryVariant">@color/purple_2</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/lime</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Цвета для surface -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Цвет фона -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Стиль для EditText - ОСНОВНОЕ ИСПРАВЛЕНИЕ -->
        <item name="editTextStyle">@style/CustomEditTextStyle</item>

        <!-- Стиль для TextInputLayout -->
        <item name="textInputStyle">@style/CustomTextInputLayout</item>
    </style>

    <!-- Стиль для EditText -->
    <style name="CustomEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:background">@drawable/bg_edittext</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Стиль для TextInputLayout -->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxStrokeColor">@color/purple_1</item>
        <item name="hintTextColor">@color/purple_1</item>
    </style>

</resources>