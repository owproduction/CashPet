<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_primary"
        app:titleTextColor="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Карточка приветствия -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Добро пожаловать!"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_primary"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/purple_bg"
                            app:cardCornerRadius="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp"
                                android:gravity="center">
                                <TextView android:text="🥕" android:textSize="16sp"/>
                                <TextView android:id="@+id/tvFoodCurrency"
                                    android:text="100"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/purple_primary"
                                    android:layout_marginStart="6dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="@color/purple_bg"
                            app:cardCornerRadius="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp"
                                android:gravity="center">
                                <TextView android:text="🍯" android:textSize="16sp"/>
                                <TextView android:id="@+id/tvBalance"
                                    android:text="15 000 ₽"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/purple_primary"
                                    android:layout_marginStart="6dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Карточка питомца -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/petContainer"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardBackgroundColor="@color/purple_bg">

                        <TextView
                            android:id="@+id/tvPetEmoji"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🐹"
                            android:textSize="48sp"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Копилко-хомяк"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_primary"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:text="😊 Настроение:"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvMoodText"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:text="Отличное!"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/purple_light"
                                android:gravity="end"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:text="Энергия:"
                                android:textSize="12sp"/>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressEnergy"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:progress="80"
                                app:trackColor="@color/gray_border"
                                app:indicatorColor="@color/lime"/>

                            <TextView
                                android:id="@+id/tvEnergyPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="80%"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Кнопка кормления -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeedPet"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:text="🥕 Покормить (10 корма)"
                android:textAllCaps="false"
                app:backgroundTint="@color/purple_primary"/>

            <!-- Кнопки действий -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:id="@+id/btnAddExpense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:text="💸" android:textSize="32sp"/>
                        <TextView android:text="Расход" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="@color/expense"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:id="@+id/btnAddIncome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:text="💰" android:textSize="32sp"/>
                        <TextView android:text="Доход" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="@color/income"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Уведомление -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/purple_bg"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="20sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tvNotification"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Уведомление"
                android:textSize="14sp"
                android:textColor="@color/purple_primary"/>

            <Button
                android:id="@+id/btnCloseNotification"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:background="@android:color/transparent"
                android:textColor="@color/purple_primary"
                android:textSize="14sp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#80000000"
        android:gravity="center"/>

</LinearLayout>