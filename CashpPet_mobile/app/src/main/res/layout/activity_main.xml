<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Верхняя панель (Toolbar) -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4CAF50"
        app:titleTextColor="#FFFFFF"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>

    <!-- Приветствие -->
    <TextView
        android:id="@+id/textViewWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Привет, Игрок!"
        android:textSize="28sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp"/>

    <!-- Панель с валютой -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/textViewBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍯 15,000 ₽"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginEnd="24dp"/>

        <TextView
            android:id="@+id/textViewFood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥕 100"
            android:textSize="18sp"
            android:textColor="#FF9800"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Кнопки меню в GridLayout -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="3"
        android:padding="16dp">

        <!-- Добавить трату - оранжево-красный (#FF5722) -->
        <Button
            android:id="@+id/buttonExpense"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/button_orange_red_background"
            android:text="💸 Добавить трату"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"/>

        <!-- Добавить доход - зеленый (#4CAF50) -->
        <Button
            android:id="@+id/buttonIncome"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/button_green_background"
            android:text="💰 Добавить доход"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"/>

        <!-- Мои цели - синий (#2196F3) -->
        <Button
            android:id="@+id/buttonGoals"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/button_blue_background"
            android:text="🎯 Мои цели"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"/>

        <!-- Графики - фиолетовый (#9C27B0) -->
        <Button
            android:id="@+id/buttonCharts"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/button_purple_background"
            android:text="📊 Графики"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"/>

        <!-- Мой питомец - золотой/желтый (#FFC107) - занимает 2 колонки -->
        <Button
            android:id="@+id/buttonPet"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_columnSpan="2"
            android:layout_margin="8dp"
            android:background="@drawable/button_gold_background"
            android:text="🐹 Мой питомец"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"/>

    </GridLayout>

    <!-- Кнопка профиля внизу - серая -->
    <Button
        android:id="@+id/buttonProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="@drawable/button_gray_background"
        android:text="👤 Профиль"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:gravity="center"/>
</LinearLayout>