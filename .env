import pygame
import random

# Инициализация
pygame.init()
width, height = 600, 400
screen = pygame.display.set_mode((width, height))
clock = pygame.time.Clock()

# Цвета
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
RED = (255, 0, 0)
GREEN = (0, 255, 0)

# Настройки
snake_pos = [100, 50]
snake_body = [[100, 50], [90, 50], [80, 50]]
direction = 'RIGHT'
change_to = direction
lives = 3
score = 0

# Астероиды (x, y)
good_ast = [random.randrange(1, (width//10)) * 10, random.randrange(1, (height//10)) * 10]
bad_ast = [random.randrange(1, (width//10)) * 10, random.randrange(1, (height//10)) * 10]

def show_info():
    font = pygame.font.SysFont('Arial', 20)
    img = font.render(f'Жизни: {lives}  Счет: {score}', True, WHITE)
    screen.blit(img, (10, 10))

while lives > 0:
    for event in pygame.event.get():
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_UP and direction != 'DOWN': change_to = 'UP'
            if event.key == pygame.K_DOWN and direction != 'UP': change_to = 'DOWN'
            if event.key == pygame.K_LEFT and direction != 'RIGHT': change_to = 'LEFT'
            if event.key == pygame.K_RIGHT and direction != 'LEFT': change_to = 'RIGHT'

    direction = change_to
    if direction == 'UP': snake_pos[1] -= 10
    if direction == 'DOWN': snake_pos[1] += 10
    if direction == 'LEFT': snake_pos[0] -= 10
    if direction == 'RIGHT': snake_pos[0] += 10

    # Механика роста
    snake_body.insert(0, list(snake_pos))
    if snake_pos == good_ast:
        score += 1
        good_ast = [random.randrange(1, (width//10)) * 10, random.randrange(1, (height//10)) * 10]
    else:
        snake_body.pop()

    # Столкновение с плохим астероидом
    if snake_pos == bad_ast:
        lives -= 1
        bad_ast = [random.randrange(1, (width//10)) * 10, random.randrange(1, (height//10)) * 10]

    # Смерть от стен или себя
    if snake_pos[0] < 0 or snake_pos[0] > width-10 or snake_pos[1] < 0 or snake_pos[1] > height-10:
        lives -= 1
        snake_pos = [100, 50] # Респаун

    screen.fill(BLACK)
    for pos in snake_body:
        pygame.draw.rect(screen, GREEN, pygame.Rect(pos[0], pos[1], 10, 10))
    
    pygame.draw.circle(screen, WHITE, (good_ast[0]+5, good_ast[1]+5), 5) # Хороший
    pygame.draw.circle(screen, RED, (bad_ast[0]+5, bad_ast[1]+5), 5)    # Плохой
    
    show_info()
    pygame.display.flip()
    clock.tick(15)

pygame.quit()